// ================================================================
// nextflow.config — Multivariate GWAS Pipeline · CDC 1.0.0
// Author : Nadeem Khan, INRS-CAFSB
// ================================================================

manifest {
    name            = 'multivariate-gwas-pipeline'
    author          = 'Nadeem Khan, INRS-CAFSB'
    description     = 'Multivariate hypothesis testing, regression, MTC, and causal inference on GWAS sumstats'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
    mainScript      = 'main.nf'
    homePage        = 'https://github.com/nkhan119'
}

// ── Global safe defaults (overridden per profile) ─────────────
// Critical: docker.enabled = false prevents NF from trying to pull
// containers even when the Docker daemon is running on the machine.
docker.enabled      = false
singularity.enabled = false
conda.enabled       = false

// ── Parameters ─────────────────────────────────────────────────
params {
    base_dir     = "/home/nadeem/Downloads/1000G_phase3_common_norel"
    sumstats_dir = "${params.base_dir}/GWAS_analysis"
    out_dir      = "${projectDir}/results"

    // Only used with -profile docker or singularity
    docker_image = "nkhan119/cdc-multivariate:1.0.0"

    author      = "Nadeem Khan"
    institute   = "INRS-Centre Armand-Frappier Sante-Biotechnologie, Laval, QC, Canada"
    affiliation = "Bioinformatician"
}

// ── Process defaults (timing/resources only — NO conda/container) ─
process {
    errorStrategy = { task.exitStatus in [130,137,140] ? 'retry' : 'finish' }
    maxRetries    = 2

    withName: 'MULTIVARIATE_ANALYSIS' {
        cpus   = 8
        memory = { 24.GB * task.attempt }
        time   = '4h'
    }
}

// ── Profiles ───────────────────────────────────────────────────
profiles {

    // ── LOCAL — conda, no container ────────────────────────────
    // Usage:  nextflow run main.nf -profile local,conda
    local {
        process.executor    = 'local'
        executor { cpus = 16; memory = '64 GB' }
        docker.enabled      = false
        singularity.enabled = false
        conda.enabled       = true
        conda.useMamba      = false
        process {
            withName: 'MULTIVARIATE_ANALYSIS' {
                conda     = "${projectDir}/envs/multivariate_env.yaml"
                container = null
            }
        }
    }

    // ── CONDA — pair with local or slurm ────────────────────────
    // Usage:  nextflow run main.nf -profile local,conda
    conda {
        docker.enabled      = false
        singularity.enabled = false
        conda.enabled       = true
        conda.useMamba      = false
        process {
            withName: 'MULTIVARIATE_ANALYSIS' {
                conda     = "${projectDir}/envs/multivariate_env.yaml"
                container = null
            }
        }
    }

    // ── DOCKER — only after building image locally ───────────────
    // Build:  cd ~/Downloads/multivariate-pipeline
    //         docker build -f docker/Dockerfile -t nkhan119/cdc-multivariate:1.0.0 .
    // Usage:  nextflow run main.nf -profile docker
    docker {
        docker.enabled      = true
        docker.runOptions   = '--rm -u $(id -u):$(id -g)'
        singularity.enabled = false
        conda.enabled       = false
        process {
            withName: 'MULTIVARIATE_ANALYSIS' {
                container = params.docker_image
            }
        }
    }

    // ── SINGULARITY — any HPC without Docker ────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
        process {
            withName: 'MULTIVARIATE_ANALYSIS' {
                container = "docker://${params.docker_image}"
            }
        }
    }

    // ── NARVAL — SLURM + Singularity (Compute Canada) ───────────
    narval {
        process.executor       = 'slurm'
        process.clusterOptions = '--account=def-fveyrier_cpu'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
        executor {
            queueSize       = 50
            pollInterval    = '30 sec'
            submitRateLimit = '10/1min'
        }
        process {
            withName: 'MULTIVARIATE_ANALYSIS' {
                container = "docker://${params.docker_image}"
                queue     = 'def-fveyrier_cpu'
                cpus      = 16
                memory    = { 48.GB * task.attempt }
                time      = '6h'
            }
        }
    }

    test {
        process.memory = '8 GB'
        process.time   = '1h'
    }
}

// ── Execution reports ──────────────────────────────────────────
def ts = new java.text.SimpleDateFormat("yyyyMMdd_HHmm").format(new Date())
trace    { enabled = true; file = "${params.out_dir}/logs/trace_${ts}.txt";       overwrite = true }
report   { enabled = true; file = "${params.out_dir}/logs/nf_report_${ts}.html";  overwrite = true }
timeline { enabled = true; file = "${params.out_dir}/logs/timeline_${ts}.html";   overwrite = true }
dag      { enabled = true; file = "${params.out_dir}/logs/dag.svg";               overwrite = true }
